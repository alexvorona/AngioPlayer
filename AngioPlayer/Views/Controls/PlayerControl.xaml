<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="AngioPlayer.Views.Controls.PlayerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AngioPlayer.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:AngioPlayer.Views.Converters"
    mc:Ignorable="d"
    Width="800"
    Height="720"
    MaxWidth="1920"
    MaxHeight="1080"
    MinWidth="800"
    MinHeight="720"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    >    
    
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:ButtonImageConverter x:Key="ButtonImageConverter"/>        
    </UserControl.Resources>
    <Border>
        <Grid x:Name="RootGrid" Padding="20" RowSpacing="16" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>            
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <!-- Header / ComboBox -->
                <RowDefinition Height="Auto"/>
                <!-- Slider / Buttons -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left column -->
            <TextBlock
            Grid.Row="0" Grid.Column="0"
            Text="Player"
            FontSize="22"
            FontWeight="SemiBold"
            VerticalAlignment="Center"/>

            <Slider
            Grid.Row="1" Grid.Column="0"
            Minimum="0"
            Maximum="{Binding SliderMax}"
            Value="{Binding CurrentFrame, Mode=TwoWay}"/>

            <!-- Right column -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <!-- ComboBox -->
                <ComboBox
                Width="350" Height="34"
                ItemsSource="{Binding Scans}"
                SelectedItem="{Binding SelectedScan, Mode=TwoWay}" />
                <!-- Load Button -->
                <Button Width="70" Height="34"
                Command="{Binding LoadCommand}">
                    <Image Width="24" Height="24">
                        <Image.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/Load.svg"/>
                        </Image.Source>
                    </Image>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <!-- Buttons -->
                <Button x:Name="PrevButton" Command="{Binding PrevCommand}" IsEnabled="{Binding IsPrevEnabled}">
                    <Image Width="24"
                           Height="24"
                           Source="{Binding IsEnabled,
                            ElementName=PrevButton,
                            Converter={StaticResource ButtonImageConverter},
                            ConverterParameter=Prev}"/>
                </Button>
                <!-- Play Button -->
                <Button x:Name="PlayButton" Command="{Binding PlayCommand}" IsEnabled="{Binding IsPlayEnabled}"
                        Visibility="{Binding IsPlaying, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Image Width="24"
                           Height="24"
                           Source="{Binding IsEnabled,
                            ElementName=PlayButton,
                            Converter={StaticResource ButtonImageConverter},
                            ConverterParameter=Play}"/>
                </Button>
                <!-- Pause Button -->
                <Button x:Name="PauseButton" Command="{Binding PauseCommand}" IsEnabled="{Binding IsPauseEnabled}"
                        Visibility="{Binding IsPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Image Width="24"
                           Height="24"
                           Source="{Binding IsEnabled,
                            ElementName=PauseButton,
                            Converter={StaticResource ButtonImageConverter},
                            ConverterParameter=Pause}"/>
                </Button>
                <Button x:Name="NextButton" Command="{Binding NextCommand}" IsEnabled="{Binding IsNextEnabled}">
                    <Image Width="24"
                           Height="24"
                           Source="{Binding IsEnabled,
                            ElementName=NextButton,
                            Converter={StaticResource ButtonImageConverter},
                            ConverterParameter=Next}"/>
                </Button>
                <ComboBox
                Width="120" Height="36"
                ItemsSource="{Binding Speeds}"
                SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}"
                IsEnabled="{Binding IsSpeedEnabled}"/>
                <Button x:Name="KeyButton" Width="70"
                Command="{Binding KeyImageCommand}" IsEnabled="{Binding IsKeyEnabled}">
                    <Image Width="50" Height="24"
                           Source="{Binding IsEnabled,
                            ElementName=KeyButton,
                            Converter={StaticResource ButtonImageConverter},
                            ConverterParameter=key}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT (Planes) -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!-- PLANE A -->
            <StackPanel Grid.Column="0">
                <TextBlock
                Text="PLANE A"
                HorizontalAlignment="Center"
                Margin="0,0,0,6"
                Opacity="0.7"/>
                <Border
                CornerRadius="10"
                Background="#E5E5E5"
                Padding="10">
                    <Image
                    Stretch="Uniform"
                    Source="{Binding PlaneAImage}"/>
                </Border>
            </StackPanel>

            <!-- PLANE B -->
            <StackPanel Grid.Column="1">
                <TextBlock
                Text="PLANE B"
                HorizontalAlignment="Center"
                Margin="0,0,0,6"
                Opacity="0.7"/>
                <Border
                CornerRadius="10"
                Background="#E5E5E5"
                Padding="10">
                    <Image
                    Stretch="Uniform"
                    Source="{Binding PlaneBImage}"/>
                </Border>
            </StackPanel>
        </Grid>

        </Grid>
    </Border>
</UserControl>
